# ===== KryMark configuration =====
# Copy to .env and fill in. Only the first block is REQUIRED.

# --- Required ---
# Public URL of this KryMark instance (used in emails, snippets, prompts)
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
# PocketBase superuser impersonate token — generate with: node pb/gen-superuser-token.mjs
PB_SUPERUSER_TOKEN=
# Random secret for IP hashing + re-review links: openssl rand -hex 16
IP_HASH_SALT=

# --- Docker ports (host side) ---
APP_PORT=3000
PB_ADMIN_PORT=8091

# --- Internal (defaults are fine in docker compose) ---
PB_URL=http://pocketbase:8090

# --- Rate limits for the public /api/report endpoint ---
RATE_LIMIT_PER_IP_MIN=10
RATE_LIMIT_PER_PROJECT_DAY=500

# --- Optional: screenshots on S3 (public URLs embedded in AI prompts) ---
# Without S3, screenshots are stored inside PocketBase and proxied by the app.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET=

# --- Optional: transactional email via AWS SES (resolve notifications, password reset) ---
# Without SES, everything works — emails are just skipped.
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_REGION=
SES_FROM="KryMark <no-reply@yourdomain.com>"
SES_CONFIG_SET=

# --- Optional: Telegram ping on every new note ---
TG_BOT_TOKEN=
TG_CHAT_ID=

# --- Optional: weekly digest cron (POST /api/cron/digest with this bearer) ---
CRON_SECRET=
